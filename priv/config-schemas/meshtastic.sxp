((enabled (type bool) (default false))
 (role (type enum) (values client client_mute router) (default client))
 (node_info_interval_s (type int) (default 3600) (nvs ni_secs))
 (want_response_broadcast (type bool) (default true) (nvs want_resp))
 (ok_to_mqtt (type bool) (default true))
 (hop_limit (type int) (default 3))
 (rebroadcast (type bool) (default true))
 (channel_name (type string))
 (channel_psk (type string))
 (position_precision_bits (type int) (nvs precision)))
